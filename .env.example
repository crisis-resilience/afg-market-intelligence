# Copy this file to .env and fill in your values.

# UN Comtrade API subscription key
# Obtain from: https://unstats.un.org/wiki/display/comtrade/UN+Comtrade+API
COMTRADE_API_KEY=your_api_key_here

# PostgreSQL connection string
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/afg_market

# Optional: override Postgres password when using docker-compose
POSTGRES_PASSWORD=postgres
